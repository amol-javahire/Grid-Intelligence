##############################################################################
# Grid Intelligence Platform — Environment Variables
#
# Copy this file to .env in the repo root and fill in all values.
# The .env file is gitignored — never commit actual secrets.
#
# Labels:
#   [RUNTIME]  — required for the app to start and serve requests
#   [SEED]     — only needed when running seed-on-azure.sh; not needed for runtime
#   [OPTIONAL] — feature degrades gracefully without it
##############################################################################


# ── Database (Azure Database for PostgreSQL Flexible Server + TimescaleDB) ────
# [RUNTIME]  Used by Node API (api-server) at startup.
#            Format: postgresql://<user>:<password>@<server>.postgres.database.azure.com:5432/<dbname>?sslmode=require
#            SSL is REQUIRED for Azure PostgreSQL — include ?sslmode=require
#            Find your server name in: Azure Portal → PostgreSQL Flexible Server → Overview → Server name
DATABASE_URL=postgresql://gridadmin:CHANGE_ME@your-server.postgres.database.azure.com:5432/grid_origination?sslmode=require


# ── Node API ──────────────────────────────────────────────────────────────────
# [RUNTIME]  Must match value in ecosystem.config.js
NODE_ENV=production

# [RUNTIME]  Random 32+ char string. Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=CHANGE_ME_generate_a_random_32_char_string


# ── OpenAI (Q&A Copilot page) ─────────────────────────────────────────────────
# [OPTIONAL] Platform runs without this; Q&A Copilot will show "not configured".
AI_INTEGRATIONS_OPENAI_API_KEY=sk-...
AI_INTEGRATIONS_OPENAI_BASE_URL=https://api.openai.com/v1


# ── Ports (informational — ecosystem.config.js sets these for PM2) ────────────
# API_PORT=8080
# PYPSA_PORT=8083


##############################################################################
# SEEDING-ONLY VARIABLES
# These are NOT needed at app runtime — only when running seed-on-azure.sh.
# You can remove them from .env on the EC2 instance after seeding is done,
# or leave them; the app ignores unrecognised env vars.
##############################################################################

# ── ERCOT API (SCED dispatch seeder: seed-ercot-dispatch.py) ─────────────────
# [SEED]  Obtain from ERCOT API registration: https://apiexplorer.ercot.com/
ERCOT_USERNAME=
ERCOT_PASSWORD=
ERCOT_CLIENT_ID=
ERCOT_SUBSCRIPTION_KEY=

# ── EIA API (load, fuel mix, generator attributes seeders) ────────────────────
# [SEED]  Free key at: https://www.eia.gov/opendata/register.php
EIA_API_KEY=

# ── Commodity price API ───────────────────────────────────────────────────────
# [SEED]  Used by seed-gas-forwards.ts
OIL_PRICE_API_KEY=


##############################################################################
# NOT needed for Grid Intelligence (separate AESO app)
# AESO_API_KEY=
##############################################################################
